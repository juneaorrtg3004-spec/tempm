{
  "name": "temp-mail-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create temp-mail-db",
    "db:init": "wrangler d1 execute temp-mail-db --file=./schema.sql --remote",
    "db:init-local": "wrangler d1 execute temp-mail-db --file=./schema.sql --local"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.5.0",
    "wrangler": "^3.99.0"
  }
}
